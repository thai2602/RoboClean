# Spring Boot Profile
SPRING_PROFILES_ACTIVE=dev

# Database configurations (defaults to H2 in dev, use Postgres for prod)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/robocleandb
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=your-db-password

# OpenRouter API configurations for chatbot AI advisor
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemini-2.5-flash

# CORS configuration for Frontend url
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Telemetry Webhook configuration (e.g. webhook.site, Make, or custom target)
TRACKING_WEBHOOK_URL=https://webhook.site/your-webhook-id
