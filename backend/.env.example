# Spring Boot Profile
SPRING_PROFILES_ACTIVE=dev

# Database configurations (defaults to H2 in dev, use Postgres for prod)
SPRING_DATASOURCE_URL=jdbc:postgresql://your-postgres-db-host/robocleandb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-db-password

# Google Gemini API key for chatbot AI advisor
GEMINI_API_KEY=your-gemini-api-key-here

# CORS configuration for Frontend url
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Telemetry Webhook configuration (e.g. webhook.site, Make, or custom target)
TRACKING_WEBHOOK_URL=https://webhook.site/your-webhook-id
